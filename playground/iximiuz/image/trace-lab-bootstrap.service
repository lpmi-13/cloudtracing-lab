[Unit]
Description=Bootstrap Cloud Tracing Lab
After=network.target k3s.service kubeconfig-setup.service
Wants=k3s.service kubeconfig-setup.service

[Service]
Type=oneshot
User=root
Environment=KUBECONFIG=/etc/rancher/k3s/k3s.yaml
ExecStart=/opt/iximiuz-labs/bootstrap-trace-lab.sh
RemainAfterExit=yes
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
